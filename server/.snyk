# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-JS-SHELLQUOTE-16799355:
    - '*':
      reason: Dev Dependancy, only affects npm run watch command
      expires: 2026-06-05T23:59:59.999-05:00
      created: 2026-05-26T00:00:00.000-05:00

#  EXAMPLE-VULNERABILITY:
#    - '*':
#        reason: Some reason.
#        expires: 2025-12-31T23:59:59.999-05:00
#        created: 2025-01-01T00:00:00.000-05:00
patch: {}
exclude:
  global:
    - node_modules
