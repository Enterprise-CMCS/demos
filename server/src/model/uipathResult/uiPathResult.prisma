model UiPathResult {
  id            String   @id @default(uuid()) @db.Uuid
  requestId     String   @unique @map("request_id")
  response      Json     @db.JsonB
  projectId     String   @map("project_id")
  documentId    String   @unique @map("document_id") @db.Uuid
  applicationId String   @map("application_id") @db.Uuid
  statusId      String   @default("Pending") @map("status_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  status       UiPathStatus  @relation(fields: [statusId], references: [id])
  uiPathValues UiPathValue[]
  document     Document      @relation(fields: [documentId], references: [id])

  @@unique([id, documentId, applicationId])
  @@map("uipath_result")
}
