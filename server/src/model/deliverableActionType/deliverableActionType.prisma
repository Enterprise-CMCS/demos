// Flags: STATIC_CONSTRAINT
model DeliverableActionType {
  id                   String
  dueDateChangeAllowed Boolean @map("due_date_change_allowed")

  deliverableActions                   DeliverableAction[]
  deliverableActionConfigurations      DeliverableActionConfiguration[]
  deliverableSubmissionActionTypeLimit DeliverableSubmissionActionTypeLimit[]

  @@id([id])
