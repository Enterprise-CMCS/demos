model Reference {
  id                String   @default(uuid()) @db.Uuid
  name              String
  description       String
  s3Path            String   @map("s3_path")
  ownerUserId       String   @map("owner_user_id") @db.Uuid
  ownerPersonTypeId String   @map("owner_person_type_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  owner                       User                         @relation(fields: [ownerUserId, ownerPersonTypeId], references: [id, personTypeId])
  ownerPersonType             CmsUserPersonTypeLimit       @relation(fields: [ownerPersonTypeId], references: [id])
  referenceConfigurations     ReferenceConfiguration[]
  referenceTagAssignments     ReferenceTagAssignment[]
  referenceDemonstrationTypes ReferenceDemonstrationType[]

  @@id([id])
  @@map("reference")
}
