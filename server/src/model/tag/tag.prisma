model Tag {
  tagNameId String   @map("tag_name_id")
  tagTypeId String   @map("tag_type_id")
  sourceId  String   @map("source_id")
  statusId  String   @map("status_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tagName                         TagName                          @relation(fields: [tagNameId], references: [id])
  tagType                         TagType                          @relation(fields: [tagTypeId], references: [id])
  source                          TagSource                        @relation(fields: [sourceId], references: [id])
  status                          TagStatus                        @relation(fields: [statusId], references: [id])
  applicationTagAssignments       ApplicationTagAssignment[]
  demonstrationTypeTagAssignments DemonstrationTypeTagAssignment[]

  @@id([tagNameId, tagTypeId])
  @@map("tag")
}
