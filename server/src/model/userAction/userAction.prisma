// Flags: NO_CREATED_TS, NO_UPDATED_TS
// Time is captured by the action timestamp; table is intended to be append-only
model UserAction {
  id              String   @default(uuid()) @db.Uuid
  actionTimestamp DateTime @map("action_timestamp") @db.Timestamptz
  userId          String   @map("user_id") @db.Uuid
  personTypeId    String   @map("person_type_id")
  actionTypeId    String   @map("action_type_id")

  user       User           @relation(fields: [userId, personTypeId], references: [id, personTypeId])
  actionType UserActionType @relation(fields: [actionTypeId], references: [id])

  @@id([id])
  @@map("user_action")
}
