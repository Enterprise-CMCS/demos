model UserActionHistory {
  revisionId      Int          @id @default(autoincrement()) @map("revision_id")
  revisionType    RevisionType @map("revision_type")
  modifiedAt      DateTime     @default(now()) @map("modified_at") @db.Timestamptz
  id              String       @db.Uuid
  actionTimestamp DateTime     @map("action_timestamp") @db.Timestamptz
  userId          String       @map("user_id") @db.Uuid
  personTypeId    String       @map("person_type_id")
  actionTypeId    String       @map("action_type_id")

  @@map("user_action_history")
}
