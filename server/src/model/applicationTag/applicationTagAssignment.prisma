model ApplicationTagAssignment {
  applicationId String @map("application_id") @db.Uuid
  tagNameId     String @map("tag_name_id")
  tagTypeId     String @map("tag_type_id")

  application Application             @relation(fields: [applicationId], references: [id])
  tag         Tag                     @relation(fields: [tagNameId, tagTypeId], references: [tagNameId, tagTypeId])
  tagType     ApplicationTagTypeLimit @relation(fields: [tagTypeId], references: [id])

  @@id([applicationId, tagNameId])
  @@map("application_tag_assignment")
}
