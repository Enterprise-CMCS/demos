// Flags: STATIC_CONSTRAINT
model Phase {
  id          String
  phaseNumber Int    @map("phase_number")

  phaseDocumentTypes PhaseDocumentType[]
  phaseDateTypes     PhaseDateType[]
  phaseNoteTypes     PhaseNoteType[]
  amendments         Amendment[]
  demonstrations     Demonstration[]
  extensions         Extension[]
  phasePhaseStatuses PhasePhaseStatus[]

  @@id([id])
  @@unique([phaseNumber])
  @@map("phase")
}
