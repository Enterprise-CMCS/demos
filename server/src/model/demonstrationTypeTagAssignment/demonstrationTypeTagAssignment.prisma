model DemonstrationTypeTagAssignment {
  demonstrationId String   @map("demonstration_id") @db.Uuid
  tagNameId       String   @map("tag_name_id")
  tagTypeId       String   @map("tag_type_id")
  effectiveDate   DateTime @map("effective_date") @db.Timestamptz
  expirationDate  DateTime @map("expiration_date") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  demonstration                 Demonstration                  @relation(fields: [demonstrationId], references: [id])
  tag                           Tag                            @relation(fields: [tagNameId, tagTypeId], references: [tagNameId, tagTypeId])
  tagType                       DemonstrationTypeTagTypeLimit  @relation(fields: [tagTypeId], references: [id])
  deliverableDemonstrationTypes DeliverableDemonstrationType[]

  @@id([demonstrationId, tagNameId])
  @@map("demonstration_type_tag_assignment")
}
