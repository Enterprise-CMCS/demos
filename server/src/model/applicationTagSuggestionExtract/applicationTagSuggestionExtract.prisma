model ApplicationTagSuggestionExtract {
  suggestionId  String   @map("suggestion_id") @db.Uuid
  uiPathValueId String   @map("uipath_value_id") @db.Uuid
  applicationId String   @map("application_id") @db.Uuid
  fieldId       String   @map("field_id")
  value         String
  startPageNo   Int      @map("start_page_no")
  endPageNo     Int      @map("end_page_no")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // DEFERRED: will be manually replaced by new deferred key through migration
  suggestion  ApplicationTagSuggestion                  @relation(fields: [suggestionId, applicationId, value], references: [id, applicationId, value])
  uiPathValue UiPathValue                               @relation(fields: [uiPathValueId, applicationId, fieldId, value], references: [id, applicationId, fieldId, value])
  field       ApplicationTagSuggestionExtractFieldLimit @relation(fields: [fieldId], references: [id])

  @@id([suggestionId, uiPathValueId])
  @@map("application_tag_suggestion_extract")
}
