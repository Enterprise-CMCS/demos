model ApplicationTagSuggestion {
  applicationId String   @map("application_id") @db.Uuid
  value         String   @map("value")
  statusId      String   @map("status_id")
  replacedValue String?  @map("replaced_value")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  extracts ApplicationTagSuggestionExtract[]
  status   ApplicationTagSuggestionStatus    @relation(fields: [statusId], references: [id])

  @@id([applicationId, value])
  @@map("application_tag_suggestion")
}
