{
  "name": "demos-server",
  "version": "0.1.0",
  "type": "module",
  "overrides": {
    "@aws-sdk/client-s3": {
      "fast-xml-parser": "^5.3.6"
    },
    "fast-uri": "^4.0.1"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/aws-lambda": "^4.1.0",
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/client-secrets-manager": "^3.1081.0",
    "@aws-sdk/client-sqs": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@cj-tech-master/excelts": "^9.6.1",
    "@date-fns/tz": "^1.5.0",
    "@escape.tech/graphql-armor": "^3.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "content-disposition": "^2.0.1",
    "cookie": "^1.1.1",
    "dataloader": "^2.2.3",
    "date-fns": "^4.4.0",
    "demos-shared-library": "file:../shared_library",
    "dotenv": "^17.4.2",
    "graphql-scalars": "^1.25.0",
    "graphql-tools": "^9.0.31",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "mime-types": "^3.0.2",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "sanitize-filename": "^1.6.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "clean": "rm -rf dist; npm ci",
    "build": "prisma generate && tsc && esbuild dist/server.js --bundle --platform=node --outfile=build/server.cjs --minify --external:@yaacovcr/transform",
    "build:ci": "prisma generate && tsc && esbuild dist/server.js --bundle --platform=node --outfile=build/server.cjs --minify --external:@yaacovcr/transform",
    "depcheck": "depcheck",
    "pretest": "prisma generate",
    "predev": "prisma generate",
    "server": "node ./dist/server.js",
    "dev": "tsx watch --inspect=9229 --clear-screen=false src/local-server.ts",
    "dev:quiet": "LOG_LEVEL=info tsx watch --inspect=9229 --clear-screen=false src/local-server.ts",
    "prisma": "prisma generate --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prisma:format": "prisma format",
    "seed:reset": "npm run migrate:reset && prisma generate && npm run dbrefresh && ALLOW_SEED=true npm run seed",
    "seed": "tsx --inspect ./src/seeder.ts",
    "migrate:empty": "prisma migrate dev --create-only",
    "migrate:reset": "prisma migrate reset --force",
    "migrate:deploy": "prisma migrate deploy && npm run dbrefresh",
    "lint:debug": "node --inspect-brk $(which eslint) .",
    "test": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "coverage": "vitest run --coverage",
    "coverage:ci": "vitest run --no-color --coverage --coverage.reporter=lcov --reporter=default --reporter=vitest-sonar-reporter --outputFile=coverage/test-results.xml",
    "dbrefresh": "tsx --inspect ./src/refreshDbObjects.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/client-secrets-manager": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.9.0",
    "@graphql-tools/merge": "^9.2.0",
    "@parcel/watcher": "^2.5.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-utils": "^3.0.0",
    "graphql": "^16.14.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "prisma": "^7.9.0",
    "tsc-watch": "^7.2.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "vitest-sonar-reporter": "^3.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "@apollo/protobufjs@1.2.8": true,
    "@parcel/watcher@2.5.6": true,
    "@prisma/engines@7.8.0": true
  }
}
