{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": [
      "es2021"
    ],
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
