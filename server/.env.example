DATABASE_URL="postgresql://postgres:postgres@db:5432/demos?schema=demos_app" # pragma: allowlist secret
ALLOW_SEED=true

ALLOW_INTROSPECTION=true
UPLOAD_BUCKET="upload-bucket"
CLEAN_BUCKET="clean-bucket"
DELETED_BUCKET="deleted-bucket"
CORRUPTED_BUCKET="corrupted-bucket"

S3_ENDPOINT_LOCAL="http://localstack:4566"

LOG_LEVEL="debug"

UIPATH_QUEUE_URL="http://localstack:4566/000000000000/uipath-queue"
UIPATH_QUEUE_NAME="uipath-queue"
