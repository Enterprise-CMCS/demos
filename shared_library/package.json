{
  "name": "demos-shared-library",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./BN": {
      "types": "./dist/src/BN/index.d.ts",
      "import": "./dist/src/BN/index.js"
    },
    "./BN/extractors": {
      "types": "./dist/src/BN/extractors/index.d.ts",
      "import": "./dist/src/BN/extractors/index.js"
    },
    "./BN/rulesets": {
      "types": "./dist/src/BN/rulesets/v1/index.d.ts",
      "import": "./dist/src/BN/rulesets/v1/index.js"
    },
    "./BN/validation": {
      "types": "./dist/src/BN/validation.d.ts",
      "import": "./dist/src/BN/validation.js"
    },
    "./log": {
      "types": "./dist/src/log/index.d.ts",
      "import": "./dist/src/log/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "read-excel-file": "^8.0.3"
  }
}
