# Copy to .env in this directory to override the approved-demo script defaults.

# Must point at a local demos database.
DATABASE_URL=postgresql://localhost:5432/demos?schema=demos_app

APPROVED_DEMO_STATE_ID=MD
APPROVED_DEMO_SDG_DIVISION="Division of System Reform Demonstrations"
APPROVED_DEMO_TYPE="Serious Mental Illness (SMI)"
# This is the doc that will be repeatedly submitted as "the DOC".
APPROVED_DEMO_DOCUMENT_PATH="/workspaces/demos/junk_drawer/DEMOS DOCS/AAA_nothing_doc.pdf"

# Find an existing project officer id with:
# query ProjectOfficers { people { id fullName personType roles { role isPrimary } } }
APPROVED_DEMO_PROJECT_OFFICER_USER_ID=00000000-0000-0000-0000-000000000000
