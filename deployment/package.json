{
  "name": "deployment",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "demosctl": "demosctl/index.ts"
  },
  "overrides": {
    "@aws-sdk/client-s3": {
      "fast-xml-parser": "^5.3.6"
    }
  },
  "scripts": {
    "diff:core": "cdk diff --context stage=dev demos-dev-core",
    "deploy:core": "cdk deploy --context stage=dev demos-dev-core",
    "deploy:core:output": "cdk deploy --context stage=dev demos-dev-core --outputs-file core-outputs.json",
    "diff": "cdk diff --context stage=dev --all --no-change-set",
    "deploy": "cdk deploy --context stage=dev --all --no-change-set --require-approval=never",
    "lint": "eslint ./",
    "lint:fix": "eslint ./ --fix",
    "synth:dev": "cdk synth --context stage=dev --all",
    "test": "vitest --mode test",
    "test:ci": "vitest run --no-color --coverage --coverage.reporter=lcov --reporter=default --reporter=vitest-sonar-reporter --outputFile=coverage/test-results.xml",
    "tsc": "tsc --noEmit --skipLibCheck",
    "tsc:ci": "tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1036.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "aws-cdk-local": "^3.0.4",
    "eslint": "^10.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "vitest-sonar-reporter": "^3.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1036.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1036.0",
    "@aws-sdk/client-ec2": "^3.1036.0",
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/client-ssm": "^3.1036.0",
    "aws-cdk": "^2.1119.0",
    "aws-cdk-lib": "^2.250.0",
    "cdk-nag": "^2.38.1",
    "chalk": "^5.6.2",
    "constructs": "^10.6.0",
    "pg": "^8.20.0"
  }
}
