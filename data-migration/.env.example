PG_HOST=localhost
PG_PORT=5432
PG_DB=demos_migration
PG_USER=migration_owner
PG_PASSWORD=

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=

****************************************************************************
MYSQL_URL=*******************************************************************/${MYSQL_DB}

# --- DEMOS RDS (PostgreSQL target) ---
# The RDS admin credentials are fetched from AWS Secrets Manager on demand;
# psycopg/psql connect with sslmode=verify-full against the cached RDS CA
# bundle, and pgloader connects with sslmode=require. The secret name is
# `demos-<DEMOS_ENV>-rds-admin` unless DB_SECRET_NAME overrides it; the
# secret payload must contain username/password/host/port.
DEMOS_ENV=prod
# DB_SECRET_NAME=          # explicit override for the secret name
DB_NAME=demos
AWS_REGION=us-east-1
# RDS_CA_BUNDLE_URL=https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# NOTE: the PG_URL above is now an optional local/testing override -- when
# set it is used verbatim for both psycopg and pgloader, bypassing Secrets
# Manager. Comment it out (and the PG_* parts) to use the RDS secret.

# --- Prod-schema guard reference ---
# A live PG DSN for a reference cluster that already has the pinned Prisma
# artifact applied (the rehearsal/staging demos_app). The prod-schema guard
# (`migrate verify-prod-schema`, and the automatic checks in `migrate ddl`
# pre-DROP and `migrate preflight`) dual-attaches this reference and the live
# target via DuckDB postgres_scanner and HOLDs the cutover on any schema/seed/
# emptiness drift. REQUIRED when the target is the prod RDS (PG_URL unset);
# may be left blank for local dev (the guard then skips with a WARN).
REFERENCE_PG_URL=

# Prisma migrations live under PRISMA_MIGRATIONS_PATH in the DEMOS
# GitHub repo (one timestamp-prefixed subdirectory per migration, each
# containing a single migration.sql file). `migrate fetch-prisma`
# lists those directories via the GitHub Contents API, fetches each
# migration.sql from raw.githubusercontent.com, concatenates them
# chronologically, and verifies the SHA256 against
# reports/prisma_ddl.sha256.
PRISMA_REPO=Enterprise-CMCS/demos
PRISMA_REPO_REF=main
PRISMA_MIGRATIONS_PATH=server/src/model/migrations
# The declarative `.prisma` model files live under PRISMA_SCHEMA_PATH in
# the same repo. `migrate fetch-prisma-schema` enumerates them recursively
# (GitHub Trees API), concatenates path-sorted, and verifies the SHA256
# against reports/prisma_schema.sha256. Read-only cross-validation input
# for `migrate fk-candidates`; off the cutover apply path.
PRISMA_SCHEMA_PATH=server/src/model
# Optional: GitHub PAT to raise the unauthenticated 60/hr rate limit.
# Read-only `public_repo` scope is sufficient for public repos.
GITHUB_TOKEN=

# --- DEMOS go-live verification ---
# The DEMOS healthz endpoint the `flip` phase probes. No default: `flip`
# dies rather than verify a placeholder URL. Scheme must be http/https.
NEW_APP_HEALTHZ_URL=

# --- pgloader runner ---
# pgloader ships in two implementations that share the same command-file
# syntax: v4 (Clojure/JVM, recommended) and v3 (Common Lisp). Set PGLOADER_JAR
# to a pgloader v4 jar to run the load phases as
# `<JAVA_BIN> -Xmx<PGLOADER_DYNAMIC_SPACE_MB>m -jar <jar> <rendered.load>`;
# prefer v4 for MySQL 8 sources whose utf8mb4_0900_* collations the v3 SBCL
# build cannot read. Relative jar paths resolve against the repo root. Leave
# PGLOADER_JAR blank to use the `pgloader` binary on PATH (v3). JAVA_BIN
# defaults to `java` on PATH; set an explicit path when Java is installed
# off-PATH (e.g. /opt/homebrew/opt/openjdk/bin/java).
PGLOADER_JAR=
JAVA_BIN=
# Optional heap size in MB for the pgloader load (SBCL --dynamic-space-size or
# JVM -Xmx). Defaults to 4096.
# PGLOADER_DYNAMIC_SPACE_MB=4096
