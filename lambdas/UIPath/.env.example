AWS_ENDPOINT_URL="http://localhost:4566" # this should be set from devcontainer build.
UIPATH_CLIENT_ID="STRING" # pragma: allowlist secret
UIPATH_CLIENT_SECRET="STRING" # pragma: allowlist secret
