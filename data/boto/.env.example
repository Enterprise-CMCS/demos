# Postgres connection
DATABASE_URL=postgresql://username:password@hostname:5432/database_name # pragma: allowlist secret

# S3-compatible storage
S3_ENDPOINT_URL=https://s3.example.com
SOURCE_BUCKET=old-bucket
DESTINATION_BUCKET=new-bucket

# AWS client settings
AWS_REGION=us-east-1
AWS_PROFILE=default
DRY_RUN=1
