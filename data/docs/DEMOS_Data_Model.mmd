  %% Data Tables
  amendment:::dataTable {
    uuid id PK, FK, UK "FK054: (id, application_type_id) ∈ application.(id, application_type_id) DEFERRED<br>UK: (id, application_type_id)"
    text application_type_id FK, UK "FK054: (id, application_type_id) ∈ application.(id, application_type_id) DEFERRED<br>UK: (id, application_type_id)<br>FK057: application_type_id ∈ amendment_application_type_limit.id"
    uuid demonstration_id FK "FK055: demonstration_id ∈ demonstration.id"
    text name
    text description "NULLABLE"
    timestamptz effective_date "NULLABLE"
    text status_id FK "FK018: status_id ∈ application_status.id"
    timestamptz status_updated_at
    text current_phase_id FK "FK020: current_phase_id ∈ phase.id"
    text signature_level_id FK "FK087: signature_level_id ∈ signature_level.id<br>NULLABLE"
    text clearance_level_id FK "FK085: clearance_level_id ∈ clearance_level.id"
    timestamptz created_at
    timestamptz updated_at
    CONSTRAINT_CHECK check_non_empty_name "Validate that the name is not empty or only whitespace."
    CONSTRAINT_CHECK check_amendment_non_null_fields_when_approved  "Validate that required fields exist if amendment is approved."
    TRIGGER_BEFORE_DELETE check_that_main_record_deleted_from_application "Verify that no corresponding record exists in the application table."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    TRIGGER_BEFORE_INSERT_OR_UPDATE trim_input_text_fields "Trim input text fields."
    HAS_HISTORY true
  }

  application:::dataTable {
    uuid id PK, UK "UK: (id, application_type_id)"
    text application_type_id FK, UK "FK007: application_type_id ∈ application_type.id<br>UK: (id, application_type_id)"
    CONSTRAINT_TRIGGER_DEFERRABLE_AFTER_INSERT_OR_UPDATE check_application_type_record_exists "Verify that a corresponding record exists in the demonstration, amendment, or extension tables."
    TRIGGER_AFTER_INSERT create_phases_and_dates_for_new_application "Create phases and initial dates for new application."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    HAS_HISTORY true
  }

  application_date:::dataTable {
    uuid application_id PK, FK "FK002: application_id ∈ application.id"
    text date_type_id PK, FK "FK001: date_type_id ∈ date_type.id"
    timestamptz date_value
    timestamptz created_at
    timestamptz updated_at
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    HAS_HISTORY true
  }

  application_note:::dataTable {
    uuid application_id PK, FK "FK068: application_id ∈ application.id"
    text note_type_id PK, FK "FK069: note_type_id ∈ note_type.id"
    text content
    timestamptz created_at
    timestamptz updated_at
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    TRIGGER_BEFORE_INSERT_OR_UPDATE trim_input_text_fields "Trim input text fields."
    HAS_HISTORY true
  }

  application_phase:::dataTable {
    uuid application_id PK, FK "FK005: application_id ∈ application.id"
    text phase_id PK, FK "FK004: (phase_id, phase_status_id) ∈ phase_phase_status.(phase_id, phase_status_id)"
    text phase_status_id FK "FK004: (phase_id, phase_status_id) ∈ phase_phase_status.(phase_id, phase_status_id)"
    timestamptz created_at
    timestamptz updated_at
    TRIGGER_AFTER_UPDATE update_application_current_phase_on_phase_update "Update application current phase when phase status changes."
    TRIGGER_AFTER_UPDATE update_application_status_on_phase_update "Update the application status field when a phase changes status."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    HAS_HISTORY true
  }

  application_tag_suggestion:::dataTable {
    uuid application_id PK
    text value PK
    text status_id FK "FK135: status_id ∈ application_tag_suggestion_status.id"
    text replaced_value "NULLABLE"
    timestamptz created_at
    timestamptz updated_at
    CONSTRAINT_TRIGGER_DEFERRABLE_AFTER_INSERT_OR_UPDATE check_suggestion_has_extract "Verify that at least one extract record exists for this suggestion."
    CONSTRAINT_CHECK check_application_tag_suggestion_non_null_replaced_value_when_replaced "If the status_id is Replaced, replaced_value must be non null.<br>If the status_id is not Replaced, the replaced_value must be null."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    HAS_HISTORY true
  }

  application_tag_suggestion_extract:::dataTable {
    uuid uipath_value_id PK, FK "FK132: (uipath_value_id, application_id, field_id, value) ∈ uipath_value.(id, application_id, field_id, value)"
    uuid application_id PK, FK "FK132: (uipath_value_id, application_id, field_id, value) ∈ uipath_value.(id, application_id, field_id, value)<br>FK133: (application_id, value) ∈ application_tag_suggestion.(application_id, value) DEFERRED"
    text field_id FK "FK132: (uipath_value_id, application_id, field_id, value) ∈ uipath_value.(id, application_id, field_id, value)<br>FK134: field_id ∈ application_tag_suggestion_extract_field_limit.id"
    text value PK, FK "FK132: (uipath_value_id, application_id, field_id, value) ∈ uipath_value.(id, application_id, field_id, value)<br>FK133: (application_id, value) ∈ application_tag_suggestion.(application_id, value) DEFERRED"
    integer start_page_no
    integer end_page_no
    timestamptz created_at
    timestamptz updated_at
    TRIGGER_BEFORE_DELETE check_suggestion_deleted_if_last_extract "If this is the last extract of a suggestion, verify that the corresponding suggestion is deleted."
    TRIGGER_AFTER_INSERT upsert_suggestion_record "When a new extract is added take the following steps.<br>If no suggestion exists, insert one into application_tag_suggestion.<br>If a suggestion exists, and the status is removed, set it back to pending.<br>Otherwise do nothing."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    HAS_HISTORY true
  }

  budget_neutrality_workbook:::dataTable {
    uuid id PK, FK "FK119: (id, document_type_id) ∈ document.(id, document_type_id) DEFERRED"
    text document_type_id FK "FK119: (id, document_type_id) ∈ document.(id, document_type_id) DEFERRED<br>FK120: document_type_id ∈ budget_neutrality_workbook_document_type_limit.id"
    text validation_status_id FK "FK121: validation_status_id ∈ budget_neutrality_validation_status.id"
    jsonb validation_data
    text actuals
    double net_variance_total
    timestamptz created_at
    timestamptz updated_at
    CONSTRAINT_CHECK check_budget_neutrality_workbook_non_null_fields_when_succeeded "actuals and netVarianceTotal non null when status is succeeded"
    TRIGGER_BEFORE_DELETE check_that_main_record_deleted_from_document "Verify that no corresponding record exists in the document table."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    HAS_HISTORY true
  }

  %% NOTE: That empty line with <br>&nbsp; is a layout hack for Mermaid
  deliverable:::dataTable {
    uuid id PK, UK "UK: (id, demonstration_id, deliverable_type_id)<br>UK: (id, demonstration_id)<br>&nbsp;"
    text deliverable_type_id FK, UK "FK062: deliverable_type_id ∈ deliverable_type.id<br>UK: (id, demonstration_id, deliverable_type_id)"
    text name
    uuid demonstration_id FK, UK "FK006: (demonstration_id, demonstration_status_id) ∈ demonstration.(id, status_id)<br>UK: (id, demonstration_id, deliverable_type_id)<br>UK: (id, demonstration_id)"
    text demonstration_status_id FK "FK006: (demonstration_id, demonstration_status_id) ∈ demonstration.(id, status_id)<br>FK100: demonstration_status_id ∈ deliverable_demonstration_status_limit.id"
    text status_id FK "FK089: status_id ∈ deliverable_status.id"
    uuid cms_owner_user_id FK "FK103: (cms_owner_user_id, cms_owner_person_type_id) ∈ users.(id, person_type_id)"
    text cms_owner_person_type_id FK "FK103: (cms_owner_user_id, cms_owner_person_type_id) ∈ users.(id, person_type_id)<br>FK101: cms_owner_person_type_id ∈ cms_user_person_type_limit.id"
    timestamptz due_date
    text due_date_type_id FK "FK090: due_date_type_id ∈ deliverable_due_date_type.id"
    bool expected_to_be_submitted
    timestamptz created_at
    timestamptz updated_at
    CONSTRAINT_CHECK check_non_empty_name "Validate that the name is not empty or only whitespace."
    CONSTRAINT_CHECK check_deliverable_name_has_no_leading_trailing_whitespace "Validate that the trim of the name is identical to the name."
    TRIGGER_BEFORE_UPDATE _disable_redundant_updates "Disable redundant database updates."
    TRIGGER_BEFORE_INSERT_OR_UPDATE trim_input_text_fields "Trim input text fields."
    HAS_HISTORY true
  }

  deliverable_action:::dataTable {
    uuid id PK, UK "UK: (id, action_type_id)"
